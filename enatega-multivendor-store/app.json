{
  "expo": {
    "name": "Onitas Market Store",
    "slug": "enatega-multivendor-restaurant",
    "description": "Onitas Market Store app allows vendors to manage orders, menus, and real-time operations.",
    "version": "1.0.78",
    "orientation": "portrait",
    "icon": "./lib/assets/images/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./lib/assets/images/black.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "plugins": [
      "expo-router",

      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos for license, vehicle plate and profile image. Please allow these to continue using the app."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "multivendor.enatega.restaurant",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "$(PRODUCT_NAME) uses your location for features like finding orders nearby and tracking customer orders!",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": true,
        "NSBluetoothAlwaysUsageDescription": "We use Bluetooth to connect to your thermal printer.",
        "NSBluetoothPeripheralUsageDescription": "We use Bluetooth to connect to your thermal printer."
      }
    },
    "android": {
      "versionCode": 78,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "multivendor.enatega.restaurant",
      "adaptiveIcon": {
        "foregroundImage": "./lib/assets/images/appIcon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "extra": {
      "eas": {
        "projectId": "6a94161f-f21b-4ad9-8a04-c95b54ef0116"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
